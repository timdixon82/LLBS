# Node.js dependencies installed during development and by the CI lint step.
# Font files are copied from node_modules into assets/fonts/ and committed.
# The node_modules directory itself is not committed.
node_modules/

# npm package lock is committed; these files are not.
npm-debug.log*
.npm

# Logs
*.log

# macOS finder artefacts
.DS_Store

# Windows finder artefacts
Thumbs.db

# iCloud Drive sync-conflict artefacts. When the same file is edited in two
# places, iCloud creates siblings with numeric suffixes: `name 2.md`, etc.
# These are sync artefacts and are never intentional commits.
* 2.*
* 3.*
* 4.*
* 5.*

# Editor artefacts
.vscode/
.idea/
*.swp
*.swo

# Secrets and environment files
.env
.env.*
!.env.example
*.pem
*.key

# CI-only Pa11y config, derived from pa11y.json in the accessibility workflow.
# Generated at CI time; never committed.
pa11y.ci.json

# Claude Code local settings — local to this machine, not shared.
.claude/settings.local.json

# Session transcripts written by the session hook — local audit trail only.
.claude/transcripts/
